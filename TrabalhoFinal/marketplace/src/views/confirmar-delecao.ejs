<%- include('./includes/head') %>
<%- include('./includes/nav1') %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Confirmar Exclusão</h4>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <i class="bi bi-exclamation-triangle text-warning" style="font-size: 4rem;"></i>
                    </div>
                    
                    <h5 class="text-center mb-3">Você está prestes a deletar o produto:</h5>
                    
                    <div class="alert alert-secondary">
                        <p><strong>Nome:</strong> <%= produto.nome %></p>
                        <p><strong>Descrição:</strong> <%= produto.descricao %></p>
                        <p><strong>Preço:</strong> R$ <%= produto.preco.toFixed(2) %></p>
                    </div>

                    <p class="text-danger text-center">
                        <strong>Atenção:</strong> Esta ação é permanente e não pode ser desfeita!
                    </p>

                    <div class="d-flex gap-2 justify-content-center">
                        <a href="/meus-produtos" class="btn btn-secondary">Cancelar</a>
                        <form action="/produtos/deletar/<%= produto.id %>" method="POST">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Sim, deletar permanentemente
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<%- include('./includes/footer') %>