<!doctype html>
<html lang="pt-BR">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Buscar endereço automaticamente</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>

<body>
    <div class="container">
        <div class="row">
            <h3 class="text-center my-5">Buscar endereço por CEP</h1>
            <div class="col-log-3"></div>
            <div class="col-log-6 my-5">
                <form id="formEndereco" action="/salvar-endereco" method="POST">
                    <div class="form-group">
                        <label>CEP</label>
                        <input type="text" class="form-control my-2" id="cep">
                    </div>
                    <div class="form-group">
                        <label>Rua</label>
                        <input type="text"class="form-control my-2" id="logradouro">
                    </div>
                    <div class="form-group">
                        <label>Numero</label>
                        <input type="text"class="form-control my-2" id="numero">
                    </div>
                    <div class="form-group">
                        <label>Bairro</label>
                        <input type="text" class="form-control my-2"id="bairro">
                    </div>
                    <div class="form-group">
                        <label>Cidade</label>
                        <input type="text" class="form-control my-2"id="cidade">
                    </div>
                    <div class="form-group">
                        <label>Estado</label>
                        <input type="text" class="form-control my-2"id="estado">
                    </div>
                    <div class="form-group">
                        <label>País</label>
                        <input type="text" class="form-control my-2"id="pais" value="Brasil">
                    </div>
                    <button type="submit" class="btn btn-primary my-2">Salvar</button>
                </form>
                <pre id="resultado"></pre>
            </div>
            <div class="col-log-3"></div>
        </div>
    </div>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
    <script src="/js/app.js"></script>
</body>

</html>